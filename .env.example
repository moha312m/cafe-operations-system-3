# ─────────────────────────────────────────────────────────────
# Cafe Ops — environment variables
# Copy to `.env` for local dev, or set these in Railway → Variables.
# Never commit real secrets. This file lists names only.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (required).
# Local example:
#   postgresql://USER@localhost:5432/cafe_ops
# On Railway, reference the Postgres plugin:
#   ${{ Postgres.DATABASE_URL }}
DATABASE_URL="postgresql://user:password@host:5432/cafe_ops"

# Session/JWT signing secret (required in production).
# Auth uses a signed cookie via `jose` (NOT NextAuth), so this is the
# ONLY auth secret needed. Generate a strong value, e.g.:
#   openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# NODE_ENV is set automatically by Next.js / Railway ("production" on
# deploy). No need to set it manually.
# NODE_ENV="production"
