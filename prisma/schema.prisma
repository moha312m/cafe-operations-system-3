// Cafe Ops — multi-tenant SaaS schema.
// Tenancy model: shared database, every tenant-owned row carries `cafeId`.
// SUPER_ADMIN users have cafeId = null; everyone else is scoped to a cafe
// (and optionally pinned to a single branch via branchId).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Role {
  SUPER_ADMIN // platform operator, cross-tenant
  CAFE_OWNER // full control of one cafe and all its branches
  BRANCH_MANAGER // manages a single branch: staff, menu availability, reports
  WAITER // takes orders at the table, approves QR menu orders
  CASHIER // POS: create orders, take payments
  BARISTA // kitchen/barista: view & advance order statuses
  INVENTORY_MANAGER // stock levels per branch
}

// How the order entered the system. QR_MENU orders require waiter
// approval before they reach the kitchen.
enum OrderSource {
  QR_MENU
  WAITER
  CASHIER_POS
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING_WAITER_APPROVAL // QR menu order waiting for a waiter to review
  CONFIRMED // accepted — visible to kitchen/barista
  PREPARING // kitchen/barista working on it
  READY // ready for pickup / serving
  SERVED // delivered to customer & paid
  CANCELLED // cancelled by staff after confirmation
  REJECTED // QR order rejected by the waiter (never reached the kitchen)
}

// Per-item kitchen progress (prepared for item-level tracking; the MVP
// drives everything from the order-level status).
enum KitchenStatus {
  NEW
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET // محفظة إلكترونية (كان MOBILE_WALLET)
  MIXED // دفع مقسّم — بيتسجّل كأكتر من Payment
}

enum PaymentStatus {
  PAID
  PARTIAL
  REFUNDED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// How a cafe operates end-to-end. Drives sensible defaults for the
// feature flags + QR routing; the individual flags still win.
enum CafeWorkflowMode {
  FULL_SERVICE // كافيه كامل
  SMALL_CAFE // كافيه صغير
  TAKEAWAY_ONLY // تيك أواي فقط
  RESTAURANT // مطعم
}

// Where a QR-menu order goes the moment the customer submits it.
enum QrOrderRoutingMode {
  WAITER_APPROVAL // يذهب لموافقة الويتر (PENDING_WAITER_APPROVAL)
  CASHIER_DIRECT // يذهب للكاشير مباشرة (CONFIRMED)
  KITCHEN_DIRECT // يذهب للبار مباشرة (CONFIRMED)
  AUTO_CONFIRMED // يتأكد تلقائيًا (CONFIRMED)
}

// SaaS subscription state for a cafe tenant. Independent of `isActive`,
// which is the hard on/off switch the platform owner flips to suspend a
// cafe. TRIAL/ACTIVE keep the cafe usable; EXPIRED/SUSPENDED are shown in
// the super-admin panel and can be extended into hard enforcement later.
enum SubscriptionStatus {
  TRIAL // فترة تجريبية
  ACTIVE // اشتراك نشط
  EXPIRED // اشتراك منتهي
  SUSPENDED // اشتراك موقوف
}

// ─────────────────────────── Tenancy core ────────────────────────────

model Cafe {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("USD")
  taxRate   Decimal  @default(0) @db.Decimal(5, 2) // percent, e.g. 14.00
  isActive  Boolean  @default(true) // false = suspended by the platform owner
  // Allow serving orders even if an ingredient goes below zero. Default
  // off: serving is blocked when stock is insufficient.
  allowNegativeStock Boolean @default(false)

  // Platform suspension audit (set when isActive is flipped off).
  suspendedAt     DateTime?
  suspendedReason String?

  // SaaS subscription (placeholder billing — DB-ready, UI-visible).
  planName             String             @default("تجريبي")
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches       Branch[]
  users          User[]
  categories     MenuCategory[]
  products       Product[]
  addOns         AddOn[]
  orders         Order[]
  payments       Payment[]
  shifts         Shift[]
  auditLogs      AuditLog[]
  inventoryItems InventoryItem[]
  inventoryTxns  InventoryTransaction[]
  recipeItems    ProductRecipeItem[]
  settings       CafeSettings?
}

// Per-cafe module flags + workflow, controlled ONLY by SUPER_ADMIN.
// One row per cafe (created with defaults on demand). Cafe owners/staff
// can use enabled features but can never flip a flag themselves.
model CafeSettings {
  id     String @id @default(cuid())
  cafeId String @unique

  workflowMode       CafeWorkflowMode   @default(FULL_SERVICE)
  qrOrderRoutingMode QrOrderRoutingMode @default(WAITER_APPROVAL)

  // Feature flags
  aiAssistantEnabled     Boolean @default(false)
  qrMenuEnabled          Boolean @default(true)
  waiterApprovalEnabled  Boolean @default(true)
  kitchenScreenEnabled   Boolean @default(true)
  inventoryEnabled       Boolean @default(true)
  shiftManagementEnabled Boolean @default(true)
  advancedReportsEnabled Boolean @default(false)
  excelImportEnabled     Boolean @default(true)
  recipeCostingEnabled   Boolean @default(true)
  staffManagementEnabled Boolean @default(true)
  branchManagementEnabled Boolean @default(true)

  // Extra workflow switches
  requireShiftForQrOrders     Boolean @default(false)
  allowCashierToPrepareOrders Boolean @default(false)
  allowCashierToServeOrders   Boolean @default(false)
  enableTables                Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)
}

model Branch {
  id        String   @id @default(cuid())
  cafeId    String
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Customer QR menu settings: /menu/[cafe.slug]/[menuSlug]
  menuSlug          String? // latin slug for the public URL
  publicMenuEnabled Boolean @default(true)

  cafe           Cafe                 @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  users          User[]
  orders         Order[]
  payments       Payment[]
  shifts         Shift[]
  inventoryItems InventoryItem[]
  inventoryTxns  InventoryTransaction[]
  productPrices  ProductBranchPrice[]

  @@unique([cafeId, menuSlug])
  @@index([cafeId])
}

model User {
  id           String    @id @default(cuid())
  cafeId       String? // null only for SUPER_ADMIN
  branchId     String? // set for branch-level staff (manager, cashier, kitchen, inventory)
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  role         Role
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  archivedAt   DateTime? // soft delete: archived staff keep their history on orders/shifts/audit
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cafe             Cafe?      @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch           Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  ordersCreated    Order[]    @relation("OrderCreatedBy")
  ordersApproved   Order[]    @relation("OrderApprovedBy")
  ordersRejected   Order[]    @relation("OrderRejectedBy")
  paymentsReceived Payment[]
  shifts           Shift[]
  auditLogs        AuditLog[]
  inventoryTxns    InventoryTransaction[]

  @@index([cafeId])
  @@index([branchId])
}

// ─────────────────────────────── Menu ────────────────────────────────

model MenuCategory {
  id                 String   @id @default(cuid())
  cafeId             String
  name               String
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  showInCustomerMenu Boolean  @default(true) // hidden categories hide their products from the QR menu
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  cafe     Cafe      @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([cafeId])
}

model Product {
  id          String   @id @default(cuid())
  cafeId      String
  categoryId  String
  name        String
  description String?
  basePrice   Decimal  @db.Decimal(10, 2) // سعر البيع — the default sale price (EGP)
  costPrice   Decimal? @db.Decimal(10, 2) // تكلفة المنتج — for future profit reports
  imageUrl    String?
  isActive    Boolean  @default(true) // master switch: hidden everywhere when off
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Visibility & availability controls
  showInCustomerMenu Boolean @default(true) // appears on the public QR menu
  showInPOS          Boolean @default(true) // appears on the cashier/waiter POS
  isAvailable        Boolean @default(true) // orderable; shown as "غير متاح" when off
  sortOrder          Int     @default(0)

  cafe         Cafe                 @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  category     MenuCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants     ProductVariant[]
  addOns       ProductAddOn[]
  branchPrices ProductBranchPrice[]
  recipeItems  ProductRecipeItem[]
  orderItems   OrderItem[]

  @@index([cafeId])
  @@index([categoryId])
  @@index([cafeId, isAvailable])
  @@index([cafeId, showInCustomerMenu])
  @@index([cafeId, showInPOS])
  @@index([cafeId, sortOrder])
}

// A variant is a size/kind choice (صغير / وسط / كبير) with its own
// absolute price. When a product has variants, the variant price is
// the unit price; otherwise basePrice applies.
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2) // سعر الحجم (absolute, not a delta)
  isActive  Boolean @default(true) // متاح
  sortOrder Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
}

// سعر مختلف حسب الفرع — optional base-price override per branch. For
// variant products, the difference (override − basePrice) shifts every
// variant price so one override rules the whole product in that branch.
model ProductBranchPrice {
  id        String  @id @default(cuid())
  productId String
  branchId  String
  price     Decimal @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([branchId])
}

// Add-ons are cafe-wide (extra shot, whipped cream) and attached to
// products through the ProductAddOn join table.
model AddOn {
  id       String  @id @default(cuid())
  cafeId   String
  name     String
  price    Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)

  cafe          Cafe             @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  products      ProductAddOn[]
  orderItemAdds OrderItemAddOn[]

  @@index([cafeId])
}

model ProductAddOn {
  productId String
  addOnId   String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addOn   AddOn   @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([productId, addOnId])
}

// وصفة المنتج — one row per ingredient used to make one unit of the
// product. quantity is expressed in `unit` (which may differ from the
// inventory item's storage unit; conversion happens in the costing lib).
model ProductRecipeItem {
  id              String        @id @default(cuid())
  cafeId          String
  productId       String
  inventoryItemId String
  quantity        Decimal       @db.Decimal(12, 3) // per one product unit
  unit            InventoryUnit
  wastePercentage Decimal       @default(0) @db.Decimal(5, 2) // نسبة الهالك (%)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  cafe          Cafe          @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryItemId])
  @@index([cafeId])
  @@index([productId])
  @@index([inventoryItemId])
}

// ─────────────────────────────── Orders ──────────────────────────────

model Order {
  id             String      @id @default(cuid())
  cafeId         String
  branchId       String
  orderNumber    Int // human-friendly, sequential per branch
  type           OrderType   @default(DINE_IN)
  status         OrderStatus @default(CONFIRMED)
  source         OrderSource @default(CASHIER_POS)
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  tableNumber     String?
  notes           String?
  subtotal       Decimal     @db.Decimal(10, 2)
  taxAmount      Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  createdById    String? // null for QR menu orders placed by customers
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  completedAt    DateTime?

  // Kitchen/barista timeline
  preparationStartedAt DateTime?
  readyAt              DateTime?
  servedAt             DateTime?

  // Waiter approval workflow (QR menu orders only)
  approvedById    String?
  approvedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  rejectionReason String?

  // Set once ingredients are auto-deducted on SERVED (double-deduct guard)
  stockDeductedAt DateTime?

  cafe          Cafe                   @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch        Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy     User?                  @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy    User?                  @relation("OrderApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy    User?                  @relation("OrderRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payments      Payment[]
  inventoryTxns InventoryTransaction[]

  @@unique([branchId, orderNumber])
  @@index([cafeId, createdAt])
  @@index([cafeId, status])
  @@index([cafeId, source, createdAt])
  @@index([branchId, status])
  @@index([createdById])
  @@index([approvedById])
  @@index([source])
}

// Item rows snapshot name & price at sale time so menu edits never
// rewrite history.
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  variantId   String?
  productName String
  variantName String?
  unitPrice   Decimal @db.Decimal(10, 2) // base + variant delta
  quantity    Int
  lineTotal   Decimal @db.Decimal(10, 2) // (unitPrice + add-ons) * quantity
  notes       String?
  kitchenStatus KitchenStatus @default(NEW)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  addOns  OrderItemAddOn[]

  @@index([orderId])
}

model OrderItemAddOn {
  id          String  @id @default(cuid())
  orderItemId String
  addOnId     String?
  addOnName   String
  price       Decimal @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addOn     AddOn?    @relation(fields: [addOnId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
}

// ────────────────────────────── Payments ─────────────────────────────

model Payment {
  id           String        @id @default(cuid())
  cafeId       String
  branchId     String? // الفرع — مشتق من الأوردر (nullable للصفوف القديمة)
  orderId      String
  shiftId      String? // شيفت الكاشير — بيتربط لطلبات الـ POS
  cashierId    String? // الكاشير اللي حصّل — = receivedById لطلبات الـ POS
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  status       PaymentStatus @default(PAID)
  receivedById String
  paidAt       DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  cafe       Cafe    @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shift      Shift?  @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  receivedBy User    @relation(fields: [receivedById], references: [id])

  @@index([cafeId, createdAt])
  @@index([branchId])
  @@index([orderId])
  @@index([shiftId])
  @@index([cashierId])
  @@index([method])
  @@index([status])
}

// ─────────────────────────────── Shifts ──────────────────────────────
// وردية الكاشير: بتتفتح قبل تسجيل الطلبات وبتتقفل آخر اليوم بتسوية الكاش.
// كل المبالغ EGP، والأرقام التجميعية بتتحدّث مع كل دفع/مرتجع.

model Shift {
  id                 String      @id @default(cuid())
  cafeId             String
  branchId           String
  cashierId          String
  shiftNumber        Int // تسلسلي لكل فرع
  openedAt           DateTime    @default(now())
  closedAt           DateTime?
  openingCashAmount  Decimal     @default(0) @db.Decimal(10, 2)
  expectedCashAmount Decimal     @default(0) @db.Decimal(10, 2)
  actualCashAmount   Decimal? @db.Decimal(10, 2)
  cashDifference     Decimal? @db.Decimal(10, 2)
  totalSales         Decimal     @default(0) @db.Decimal(10, 2)
  totalCashSales     Decimal     @default(0) @db.Decimal(10, 2)
  totalCardSales     Decimal     @default(0) @db.Decimal(10, 2)
  totalWalletSales   Decimal     @default(0) @db.Decimal(10, 2)
  totalRefunds       Decimal     @default(0) @db.Decimal(10, 2)
  totalDiscounts     Decimal     @default(0) @db.Decimal(10, 2)
  orderCount         Int         @default(0)
  status             ShiftStatus @default(OPEN)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  cafe     Cafe      @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashier  User      @relation(fields: [cashierId], references: [id])
  payments Payment[]

  @@unique([branchId, shiftNumber])
  @@index([cafeId])
  @@index([branchId])
  @@index([cashierId])
  @@index([status])
  @@index([openedAt])
  @@index([closedAt])
  @@index([branchId, status])
}

// ───────────────────────────── Inventory ─────────────────────────────
// Minimal stock tracking so the INVENTORY_MANAGER role has a surface;
// recipe-level depletion is post-MVP.

enum InventoryUnit {
  GRAM // جرام
  KG // كيلو
  ML // مل
  LITER // لتر
  PIECE // قطعة
  BOX // علبة
  BAG // كيس
}

enum InventoryTransactionType {
  PURCHASE // شراء / إضافة مخزون (+)
  USAGE // استخدام (−)
  WASTE // هالك (−)
  ADJUSTMENT // تسوية (±)
  TRANSFER_IN // تحويل داخل (+)
  TRANSFER_OUT // تحويل خارج (−)
  RETURN // مرتجع (+)
}

// Raw materials / ingredients tracked per branch. currentStock is the
// running balance kept in sync with the InventoryTransaction ledger.
model InventoryItem {
  id           String        @id @default(cuid())
  cafeId       String
  branchId     String
  name         String
  category     String? // التصنيف (free text: قهوة، ألبان، مستهلكات…)
  unit         InventoryUnit @default(PIECE)
  currentStock Decimal       @default(0) @db.Decimal(12, 3)
  minimumStock Decimal       @default(0) @db.Decimal(12, 3)
  costPerUnit  Decimal       @default(0) @db.Decimal(12, 2)
  supplierName String?
  expiryDate   DateTime?
  isActive     Boolean       @default(true)
  archivedAt   DateTime? // soft delete
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  cafe         Cafe                   @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch       Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  transactions InventoryTransaction[]
  recipeItems  ProductRecipeItem[]

  @@index([cafeId])
  @@index([branchId])
  @@index([cafeId, isActive])
  @@index([currentStock])
  @@index([minimumStock])
}

// Immutable ledger of every stock change. currentStock on the item is
// derived from these rows (delta applied on create).
model InventoryTransaction {
  id              String                   @id @default(cuid())
  cafeId          String
  branchId        String
  inventoryItemId String
  type            InventoryTransactionType
  quantity        Decimal                  @db.Decimal(12, 3) // signed delta already applied to stock
  unitCost        Decimal?                 @db.Decimal(12, 2)
  totalCost       Decimal?                 @db.Decimal(12, 2)
  note            String?
  orderId         String? // set for automatic USAGE deductions on SERVED
  createdById     String?
  createdAt       DateTime                 @default(now())

  cafe          Cafe          @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([cafeId])
  @@index([branchId])
  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
  @@index([cafeId, createdAt])
  @@index([orderId])
}

// ───────────────────────────── Audit log ─────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  cafeId    String? // null for platform-level events (e.g. cafe created by super admin)
  userId    String?
  action    String // e.g. "order.create", "product.update", "auth.login"
  entity    String // model name
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  cafe Cafe? @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cafeId, createdAt])
}
